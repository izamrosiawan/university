   "source": [
    "from random import random\n",
    "import numpy as np\n",
    "\n",
    "#inisiasi\n",
    "\n",
    "l = 5\n",
    "d = 10\n",
    "N = 314\n",
    "Q = 0\n",
    "\n",
    "for i in range(N):\n",
    "    x = random()*d\n",
    "    t = random()*np.pi/2\n",
    "    if x < l*np.cos(t):\n",
    "        Q += 1\n",
    "\n",
    "print(f\"banyak jarum yang memotong garis: {Q}\")\n",
    "print(f\"nilai pi: {2*l*N/Q/d}\")"
   ]
